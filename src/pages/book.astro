---
import Base from "../layouts/Base.astro";
import ScaleTitleCanvas from "../components/ScaleTitleCanvas.astro";
---

<Base
  title="The Book"
  description="At the Human Scale is becoming a book: essays, Alicia conversations, diagrams, notes, and artifacts from a real AI partnership."
  alternateEsPath="/libro/"
>
  <main class="page-shell book-page book-soon-room">
    <section class="page-hero book-pdf-hero book-soon-hero">
      <p class="eyebrow">The book</p>
      <h1 class="sr-only">The book is taking shape in public.</h1>
      <ScaleTitleCanvas title="The book is taking shape in public." className="book-title-canvas wave-title-canvas" />
      <p>
        Ten essays, short conversations with Alicia, diagrams, notes, and
        artifacts from a real AI partnership. The form keeps the making visible.
        The theory should arrive through the work.
      </p>
      <p class="book-signup-note">
        Get the next essays, Alicia fragments, and book notes as the project
        develops.
      </p>
      <form name="book-page-waitlist" method="POST" data-netlify="true" action="/thanks/" class="follow-form book-waitlist-form">
        <input type="hidden" name="form-name" value="book-page-waitlist" />
        <label>
          <span>Email</span>
          <input type="email" name="email" autocomplete="email" required placeholder="you@example.com" />
        </label>
        <button type="submit">Follow the book</button>
      </form>
      <a class="button ghost" href="/#essays">Read the first essays</a>
    </section>
  </main>
</Base>
