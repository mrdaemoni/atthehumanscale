---
import Base from "../../../layouts/Base.astro";
import ScaleTitleCanvas from "../../../components/ScaleTitleCanvas.astro";
import { essays } from "../../../data/site";

export function getStaticPaths() {
  const modules = import.meta.glob("../../../essays/es/*.md", { eager: true });
  return Object.values(modules).map((mod: any) => ({
    params: { slug: mod.frontmatter.slug },
    props: { mod }
  }));
}

const { mod } = Astro.props;
const { Content } = mod;
const frontmatter = mod.frontmatter;
const essay = essays.find((item) => item.slug === frontmatter.enSlug);
const related = essays.filter((item) => item.slug !== frontmatter.enSlug);
---

<Base
  title={frontmatter.title}
  description={frontmatter.description ?? frontmatter.dek}
  image={`/og/${frontmatter.enSlug}.png`}
  lang="es"
  bodyClass="essay-body"
  alternateEnPath={`/essays/${frontmatter.enSlug}/`}
  alternateEsPath={`/ensayos/${frontmatter.slug}/`}
>
  <main class="essay-shell">
    <article class="essay-article">
      <header class="essay-header">
        <ScaleTitleCanvas title={frontmatter.title} lang="es" className="essay-title-canvas" />
        <p class="eyebrow">{essay?.number ?? "Ensayo"} / {frontmatter.date}</p>
        <h1 class="sr-only">{frontmatter.title}</h1>
        <p class="dek">{frontmatter.dek}</p>
        <p class="byline">{frontmatter.author}</p>
      </header>
      <div class="essay-content">
        <Content />
      </div>
    </article>
    <aside class="essay-aside" aria-label="Lo que hace este ensayo">
      <p class="kicker">Lo que hace este ensayo</p>
      <p>{essay?.angleEs}</p>
      {frontmatter.paperUrl && (
        <a class="text-link" href={frontmatter.paperUrl}>{frontmatter.paperTitle}</a>
      )}
    </aside>
    <nav class="next-essays" aria-label="Leer después">
      {related.map((item) => (
        <a href={`/es/ensayos/${item.esSlug}/`}>
          <span>{item.number}</span>
          <strong>{item.titleEs}</strong>
        </a>
      ))}
    </nav>
  </main>
</Base>
