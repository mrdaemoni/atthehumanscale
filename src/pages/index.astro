---
import Base from "../layouts/Base.astro";
import ScaleTitleCanvas from "../components/ScaleTitleCanvas.astro";
import { essays, site } from "../data/site";
---

<Base title={site.title} description={site.description} bodyClass="home">
  <main>
    <section class="hero home-hero" aria-labelledby="hero-title">
      <div class="hero-image" aria-hidden="true"></div>
      <ScaleTitleCanvas title="At human scale" className="home-title-canvas wave-title-canvas" />
      <div class="hero-copy">
        <h1 id="hero-title" class="sr-only">At human scale</h1>
        <div class="entry-cta" aria-label="Start reading or listening">
          <a href="#essays">Start reading</a>
          <a href="/es/#ensayos">Leer en español</a>
          <button type="button" data-player-toggle aria-label="Start listening"><span></span></button>
        </div>
        <p class="hero-dek">
          At human scale is the bridge between technology and humanity. In tech,
          scale means growth. In human life, scale means proportion. A tool at
          the wrong scale makes the person smaller. A tool at the human scale
          returns the person to themselves.
        </p>
      </div>
    </section>

    <section class="essays-preview book-index-section" id="essays" aria-labelledby="essay-index-title">
      <div class="book-index-title-field">
        <p class="eyebrow">Living index</p>
        <h2 id="essay-index-title" class="sr-only">Read or listen to the living book</h2>
        <ScaleTitleCanvas title="Read or listen to the living book" className="index-title-canvas wave-title-canvas" />
      </div>
      <section class="essay-playlist home-playlist" aria-label="Essay playlist">
        {essays.map((essay, index) => (
          <article class:list={["playlist-item", { active: index === 0 }]}>
            <div class="playlist-actions" aria-label={`Actions for ${essay.title}`}>
              <span class="playlist-number">{essay.number}</span>
              <button class="playlist-play" type="button" data-player-toggle aria-label={`Listen to ${essay.title}`}><span></span></button>
              <button
                class="playlist-share"
                type="button"
                data-share-url={`${site.domains.en}/essays/${essay.slug}/`}
                data-share-title={essay.title}
                aria-label={`Share ${essay.title}`}
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="18" cy="5" r="2.4"></circle>
                  <circle cx="6" cy="12" r="2.4"></circle>
                  <circle cx="18" cy="19" r="2.4"></circle>
                  <path d="M8.2 10.9 15.8 6.1M8.2 13.1l7.6 4.8"></path>
                </svg>
              </button>
            </div>
            <a class="playlist-copy" href={`/essays/${essay.slug}/`}>
              <div class="playlist-heading">
                <h2>{essay.title}</h2>
                <small>{essay.minutes} min</small>
              </div>
              <p>{essay.angle}</p>
            </a>
          </article>
        ))}
      </section>
    </section>

  </main>
</Base>

<script>
  (() => {
    const buttons = document.querySelectorAll("[data-share-url]");

    buttons.forEach((button) => {
      button.addEventListener("click", async () => {
        const url = button.getAttribute("data-share-url") || window.location.href;
        const title = button.getAttribute("data-share-title") || document.title;

        try {
          if (navigator.share) {
            await navigator.share({ title, url });
          } else {
            await navigator.clipboard?.writeText(url);
          }
          button.setAttribute("data-shared", "true");
          window.setTimeout(() => button.removeAttribute("data-shared"), 1200);
        } catch (_error) {
          button.removeAttribute("data-shared");
        }
      });
    });
  })();
</script>
