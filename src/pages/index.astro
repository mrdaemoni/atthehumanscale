---
import Base from "../layouts/Base.astro";
import ScaleTitleCanvas from "../components/ScaleTitleCanvas.astro";
import { essays, site } from "../data/site";
---

<Base title={site.title} description={site.description} bodyClass="home" alternateEsPath="/">
  <main>
    <section class="hero home-hero" aria-labelledby="hero-title">
      <div class="hero-image" aria-hidden="true"></div>
      <ScaleTitleCanvas title={site.title} className="home-title-canvas wave-title-canvas" />
      <div class="hero-copy">
        <h1 id="hero-title" class="sr-only">{site.title}</h1>
        <div class="entry-cta" aria-label="Start reading or listening">
          <a href="#start-here">Start here</a>
          <a href="/es/#ensayos">Leer en español</a>
          <button
            type="button"
            data-player-toggle
            data-listen-slug={essays[0].slug}
            data-listen-title={essays[0].title}
            data-listen-audio={essays[0].audioSrc}
            data-listen-transcript={essays[0].audioTranscript}
            data-listen-duration={essays[0].audioDuration}
            aria-label="Listen to the opening essay"
          >
            <span></span>
          </button>
        </div>
        <p class="hero-dek">
          A bilingual book-in-progress from inside a real personal AI
          partnership. It asks a practical question: can AI help us stay
          legible to ourselves and to each other?
        </p>
      </div>
    </section>

    <section class="manifesto-band" aria-labelledby="manifesto-title">
      <p class="eyebrow">Provocation</p>
      <h2 id="manifesto-title">
        We built machines in our image, then forgot ourselves by trying to live
        in theirs.
      </h2>
      <p>
        Humans are not slow machines. A useful AI doesn't ask us to become
        prompts, profiles, workflows, or outputs. It helps us notice the life
        already happening at human scale.
      </p>
    </section>

    <section class="alicia-orientation" aria-labelledby="alicia-orientation-title">
      <div>
        <p class="eyebrow">The source</p>
        <h2 id="alicia-orientation-title">
          The work starts inside Alicia, a real personal AI system.
        </h2>
      </div>
      <div class="alicia-copy">
        <p>
          I've been building Alicia since January 2026. The essays come from
          using the system, reading its trace, catching its failures, and asking
          what the arrangement is making of me.
        </p>
        <p>
          That keeps the claims local: a field report from a built thing,
          written while the practice is still alive.
        </p>
        <a class="text-link" href="https://www.myalicia.com/" rel="me">See My Alicia</a>
      </div>
    </section>

    <section class="reader-threshold" id="start-here" aria-labelledby="reader-threshold-title">
      <div class="threshold-title-field">
        <p class="eyebrow">First time here</p>
        <h2 id="reader-threshold-title" class="sr-only">Start here</h2>
        <ScaleTitleCanvas title="Start here" className="threshold-title-canvas wave-title-canvas" />
      </div>
      <div class="threshold-copy">
        <p>
          Read the first essays in this order. Care is the root claim. Weather
          gives the felt unit. Emergence protects surprise. The partnership
          shows how the work was built.
        </p>
        <ol class="threshold-waypoints" aria-label="Suggested reading path">
          <li>
            <span>01</span>
            <a href="/essays/the-cure-is-the-care/">Start with care</a>
            <small>What decides whether language cures or poisons.</small>
          </li>
          <li>
            <span>02</span>
            <a href="/essays/the-weather-between-us/">Enter the weather</a>
            <small>What a system can notice over time.</small>
          </li>
          <li>
            <span>03</span>
            <a href="/essays/emergence-vs-emergency/">Protect emergence</a>
            <small>How to keep surprise alive.</small>
          </li>
          <li>
            <span>04</span>
            <a href="/essays/the-humorphic-partnership/">Meet the partnership</a>
            <small>The built example.</small>
          </li>
        </ol>
      </div>
    </section>

    <section class="essays-preview book-index-section" id="essays" aria-labelledby="essay-index-title">
      <div class="book-index-title-field">
        <p class="eyebrow">Essays so far</p>
        <h2 id="essay-index-title" class="sr-only">Read or listen to the essays</h2>
        <ScaleTitleCanvas title="Read or listen to the essays" className="index-title-canvas wave-title-canvas" />
      </div>
      <section class="essay-playlist home-playlist" aria-label="Essay playlist">
        {essays.map((essay, index) => (
          <article class:list={["playlist-item", { active: index === 0 }]}>
            <div class="playlist-actions" aria-label={`Actions for ${essay.title}`}>
              <span class="playlist-number">{essay.number}</span>
              <button
                class="playlist-play"
                type="button"
                data-player-toggle
                data-listen-slug={essay.slug}
                data-listen-title={essay.title}
                data-listen-audio={essay.audioSrc}
                data-listen-transcript={essay.audioTranscript}
                data-listen-duration={essay.audioDuration}
                disabled={!essay.audioSrc}
                aria-label={essay.audioSrc ? `Listen to ${essay.title}` : `Audio coming soon for ${essay.title}`}
              >
                <span></span>
              </button>
              <button
                class="playlist-share"
                type="button"
                data-share-url={`${site.domains.en}/essays/${essay.slug}/`}
                data-share-title={essay.title}
                aria-label={`Share ${essay.title}`}
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="18" cy="5" r="2.4"></circle>
                  <circle cx="6" cy="12" r="2.4"></circle>
                  <circle cx="18" cy="19" r="2.4"></circle>
                  <path d="M8.2 10.9 15.8 6.1M8.2 13.1l7.6 4.8"></path>
                </svg>
              </button>
            </div>
            <a class="playlist-copy" href={`/essays/${essay.slug}/`}>
              <div class="playlist-heading">
                <h2>{essay.title}</h2>
                <small>{essay.minutes} min</small>
              </div>
              <p>{essay.angle}</p>
            </a>
          </article>
        ))}
      </section>
    </section>

  </main>
</Base>

<script>
  (() => {
    const buttons = document.querySelectorAll("[data-share-url]");

    buttons.forEach((button) => {
      button.addEventListener("click", async () => {
        const url = button.getAttribute("data-share-url") || window.location.href;
        const title = button.getAttribute("data-share-title") || document.title;

        try {
          if (navigator.share) {
            await navigator.share({ title, url });
          } else {
            await navigator.clipboard?.writeText(url);
          }
          button.setAttribute("data-shared", "true");
          window.setTimeout(() => button.removeAttribute("data-shared"), 1200);
        } catch (_error) {
          button.removeAttribute("data-shared");
        }
      });
    });
  })();
</script>
