---
import { site } from "../data/site";

const { lang = "en" } = Astro.props;
const isEs = lang === "es";
const path = Astro.url.pathname;

const labels = isEs
  ? {
      essays: "Ensayos",
      book: "Libro",
      about: "Hector y Alicia",
      follow: "Seguir",
      lang: "EN",
      home: site.titleEs
    }
  : {
      essays: "Essays",
      book: "Book",
      about: "Hector & Alicia",
      follow: "Follow",
      lang: "ES",
      home: site.title
    };

const langHref = isEs
  ? path.startsWith("/es/ensayos")
    ? "/#essays"
    : path.replace(/^\/es\/?/, "/") || "/"
  : path.startsWith("/essays")
    ? "/es/#ensayos"
    : "/es/";
---

<header class="site-header" data-lang={lang}>
  <a class="wordmark" href={isEs ? "/es/" : "/"} aria-label={labels.home}>
    <span>{isEs ? "La escala humana" : "At human scale"}</span>
    <small>{isEs ? "un libro en proceso" : "a living book"}</small>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href={isEs ? "/es/#ensayos" : "/#essays"}>{labels.essays}</a>
    <a href="/book/">{labels.book}</a>
    <a href="https://www.myalicia.com/" rel="me">{labels.about}</a>
    <button type="button" class="nav-button" data-follow-open>{labels.follow}</button>
    <a class="language-link" href={langHref} hreflang={isEs ? "en" : "es"}>{labels.lang}</a>
  </nav>
</header>
