---
const { lang = "en" } = Astro.props;
const isEs = lang === "es";
---

<section class="listening-stage" data-listening-stage data-theme="weather" aria-hidden="true">
  <canvas class="listening-canvas" data-listening-canvas aria-hidden="true"></canvas>
  <audio data-listening-audio preload="metadata" src="/audio/the-weather-between-us.m4a"></audio>

  <div class="listening-shell">
    <header class="listening-header">
      <div>
        <p class="eyebrow">{isEs ? "Modo escucha" : "Listening mode"}</p>
        <h2>The Weather Between Us</h2>
      </div>
      <button type="button" class="listening-close" data-listening-close aria-label={isEs ? "Cerrar escucha" : "Close listening mode"}>
        <span aria-hidden="true"></span>
      </button>
    </header>

    <div class="listening-visual" aria-live="polite">
      <p class="listening-previous" data-listening-previous></p>
      <p class="listening-current" data-listening-current></p>
      <p class="listening-next" data-listening-next></p>
    </div>

    <footer class="listening-footer">
      <span data-listening-time>0:00</span>
      <div class="listening-timeline" aria-hidden="true"><span data-listening-progress></span></div>
      <span data-listening-duration>8:57</span>
      <span class="listening-theme" data-listening-theme>weather</span>
    </footer>
  </div>
</section>

<script is:inline>
  (() => {
    const stage = document.querySelector("[data-listening-stage]");
    if (!stage) return;

    const audio = stage.querySelector("[data-listening-audio]");
    const canvas = stage.querySelector("[data-listening-canvas]");
    const ctx = canvas?.getContext("2d", { alpha: true });
    const previousEl = stage.querySelector("[data-listening-previous]");
    const currentEl = stage.querySelector("[data-listening-current]");
    const nextEl = stage.querySelector("[data-listening-next]");
    const timeEl = stage.querySelector("[data-listening-time]");
    const durationEl = stage.querySelector("[data-listening-duration]");
    const progressEl = stage.querySelector("[data-listening-progress]");
    const themeEl = stage.querySelector("[data-listening-theme]");
    const closeButton = stage.querySelector("[data-listening-close]");
    const playerTimeEl = document.querySelector("[data-player-time]");
    const playerProgressEl = document.querySelector("[data-player-progress] span");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    let transcript = null;
    let activeIndex = -1;
    let raf = 0;
    let canvasTime = 0;
    let blendedTheme = "weather";
    let blendedPalette = null;
    const asciiChars = "~≈≋⋿⊰⊱◟◝";

    const themePalettes = {
      weather: [[65, 111, 123, 0.28], [181, 66, 86, 0.16]],
      house: [[170, 118, 45, 0.24], [181, 66, 86, 0.14]],
      alicia: [[122, 160, 162, 0.3], [38, 24, 23, 0.12]],
      authorship: [[170, 49, 87, 0.22], [95, 114, 79, 0.16]],
      coda: [[38, 24, 23, 0.22], [65, 111, 123, 0.2]],
      field: [[118, 95, 88, 0.2], [181, 66, 86, 0.1]]
    };

    const poeticCues = [
      { start: 0, end: 22, text: "weather", theme: "weather", x: 0.48, y: 0.49, size: 0.2, density: 6, lead: 6, tail: 16 },
      { start: 8, end: 38, text: "slower than feeling", theme: "weather", x: 0.52, y: 0.4, size: 0.1, density: 7, lead: 8, tail: 18 },
      { start: 25, end: 58, text: "feeling needs time", theme: "field", x: 0.46, y: 0.58, size: 0.11, density: 7 },
      { start: 42, end: 74, text: "the slow unit", theme: "weather", x: 0.55, y: 0.48, size: 0.13, density: 7 },
      { start: 60, end: 92, text: "Alicia", theme: "alicia", x: 0.45, y: 0.44, size: 0.23, density: 6, tail: 20 },
      { start: 76, end: 112, text: "Alicia remembers", theme: "alicia", x: 0.54, y: 0.53, size: 0.12, density: 7 },
      { start: 96, end: 132, text: "Sunday note", theme: "house", x: 0.47, y: 0.39, size: 0.15, density: 7 },
      { start: 116, end: 156, text: "attention has duration", theme: "field", x: 0.51, y: 0.56, size: 0.1, density: 7 },
      { start: 136, end: 174, text: "weather between us", theme: "weather", x: 0.52, y: 0.45, size: 0.11, density: 7 },
      { start: 158, end: 198, text: "not instant", theme: "coda", x: 0.43, y: 0.51, size: 0.17, density: 6 },
      { start: 180, end: 220, text: "trust is architecture", theme: "house", x: 0.5, y: 0.42, size: 0.1, density: 7 },
      { start: 204, end: 238, text: "a floor", theme: "house", x: 0.58, y: 0.56, size: 0.22, density: 6 },
      { start: 226, end: 268, text: "not a cage", theme: "house", x: 0.44, y: 0.45, size: 0.16, density: 6 },
      { start: 252, end: 292, text: "relation before command", theme: "field", x: 0.52, y: 0.56, size: 0.1, density: 7 },
      { start: 278, end: 318, text: "pattern over time", theme: "weather", x: 0.47, y: 0.42, size: 0.11, density: 7 },
      { start: 304, end: 344, text: "authorship", theme: "authorship", x: 0.55, y: 0.52, size: 0.17, density: 6 },
      { start: 330, end: 372, text: "care is the interface", theme: "alicia", x: 0.5, y: 0.45, size: 0.1, density: 7 },
      { start: 358, end: 398, text: "the machine can wait", theme: "coda", x: 0.47, y: 0.57, size: 0.1, density: 7 },
      { start: 386, end: 428, text: "a life remains human", theme: "coda", x: 0.5, y: 0.42, size: 0.1, density: 7 },
      { start: 416, end: 460, text: "human scale", theme: "coda", x: 0.5, y: 0.55, size: 0.15, density: 6, lead: 10, tail: 22 },
      { start: 446, end: 486, text: "more present", theme: "alicia", x: 0.43, y: 0.45, size: 0.14, density: 7 },
      { start: 474, end: 512, text: "between us", theme: "weather", x: 0.56, y: 0.51, size: 0.15, density: 6 },
      { start: 502, end: 538, text: "weather", theme: "weather", x: 0.48, y: 0.5, size: 0.21, density: 6, lead: 8, tail: 18 }
    ];

    function formatTime(value) {
      if (!Number.isFinite(value)) return "0:00";
      const minutes = Math.floor(value / 60);
      const seconds = Math.floor(value % 60).toString().padStart(2, "0");
      return `${minutes}:${seconds}`;
    }

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function mix(start, end, amount) {
      return start + (end - start) * amount;
    }

    function colorString(color) {
      return `rgba(${color[0].toFixed(0)}, ${color[1].toFixed(0)}, ${color[2].toFixed(0)}, ${color[3].toFixed(3)})`;
    }

    function blendPalette(current, target, amount) {
      return current.map((color, index) =>
        color.map((channel, channelIndex) => mix(channel, target[index][channelIndex], amount))
      );
    }

    function paletteStrings(palette) {
      return [colorString(palette[0]), colorString(palette[1])];
    }

    function smoothstep(edge0, edge1, value) {
      const amount = clamp((value - edge0) / Math.max(0.0001, edge1 - edge0), 0, 1);
      return amount * amount * (3 - 2 * amount);
    }

    function fract(value) {
      return value - Math.floor(value);
    }

    function seeded(index, salt = 1) {
      return fract(Math.sin(index * 127.1 + salt * 311.7) * 43758.5453);
    }

    function cueEnvelope(cue, time) {
      const lead = Math.max(cue.lead ?? 16, 12);
      const tail = Math.max(cue.tail ?? 24, 20);
      const progress = clamp((time - (cue.start - lead)) / Math.max(0.001, cue.end - cue.start + lead + tail), 0, 1);
      return {
        progress,
        arrive: smoothstep(0.06, 0.58, progress),
        release: smoothstep(0.68, 1, progress),
        visible: smoothstep(0, 0.34, progress) * (1 - smoothstep(0.7, 1, progress))
      };
    }

    function topologyWave(layer, x, width, height, time) {
      const n = x / Math.max(width, 1);
      const base = height * (0.1 + layer * 0.19);
      const slow =
        Math.sin(n * Math.PI * (1.35 + layer * 0.2) + time * 0.00022 + layer * 1.7) *
        height *
        0.032;
      const small =
        Math.sin(n * Math.PI * (4.8 + layer * 0.55) + time * 0.00031 + layer) *
        height *
        0.012;
      return base + slow + small;
    }

    function drawTopologyBands(width, height, time) {
      const shades = [
        "rgba(255, 248, 239, 0.16)",
        "rgba(181, 66, 86, 0.052)",
        "rgba(244, 196, 195, 0.058)",
        "rgba(255, 248, 239, 0.105)",
        "rgba(122, 160, 162, 0.034)",
        "rgba(255, 248, 239, 0.145)"
      ];

      ctx.save();
      ctx.globalCompositeOperation = "source-over";
      shades.forEach((shade, band) => {
        ctx.beginPath();
        if (band === 0) {
          ctx.moveTo(-90, -90);
          ctx.lineTo(width + 90, -90);
          for (let x = width + 90; x >= -90; x -= 18) ctx.lineTo(x, topologyWave(0, x, width, height, time));
        } else if (band === shades.length - 1) {
          ctx.moveTo(-90, topologyWave(band - 1, -90, width, height, time));
          for (let x = -90; x <= width + 90; x += 18) ctx.lineTo(x, topologyWave(band - 1, x, width, height, time));
          ctx.lineTo(width + 90, height + 90);
          ctx.lineTo(-90, height + 90);
        } else {
          ctx.moveTo(-90, topologyWave(band - 1, -90, width, height, time));
          for (let x = -90; x <= width + 90; x += 18) ctx.lineTo(x, topologyWave(band - 1, x, width, height, time));
          for (let x = width + 90; x >= -90; x -= 18) ctx.lineTo(x, topologyWave(band, x, width, height, time));
        }
        ctx.closePath();
        ctx.fillStyle = shade;
        ctx.globalAlpha = 0.64;
        ctx.fill();
      });

      for (let layer = 0; layer < shades.length - 1; layer += 1) {
        for (let echo = -1; echo <= 1; echo += 1) {
          ctx.beginPath();
          for (let x = -90; x <= width + 90; x += 16) {
            const y =
              topologyWave(layer, x, width, height, time) +
              echo * (8 + layer * 1.5) +
              Math.sin(x * 0.008 + time * 0.0004 + layer) * 2.4;
            if (x === -90) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.globalAlpha = echo === 0 ? 0.22 : 0.09;
          ctx.strokeStyle = echo === 0 ? "rgba(65, 111, 123, 0.36)" : "rgba(38, 24, 23, 0.24)";
          ctx.lineWidth = echo === 0 ? 1 : 0.75;
          ctx.stroke();
        }
      }
      ctx.restore();
    }

    function buildWaveTextMap(cols, rows, time, activeCues, segment) {
      const letters = new Map();

      function cleanPhrase(rawPhrase, limit = 140) {
        return rawPhrase
          .toLowerCase()
          .replace(/[^a-z0-9áéíóúñü' ]/g, "")
          .replace(/\s+/g, " ")
          .trim()
          .slice(0, limit);
      }

      function placeLetter(row, col, letter, strength) {
        if (col < 0 || col >= cols || row < 0 || row >= rows) return;
        const key = `${row}:${col}`;
        const existing = letters.get(key);
        if (existing && existing.strength >= strength) return;
        letters.set(key, { letter, strength });
      }

      function addPhrase(rawPhrase, x, y, strength, seed, limit = 96) {
        const phrase = cleanPhrase(rawPhrase, limit);
        if (!phrase || strength <= 0.01) return;

        const baseRow = Math.round(y * (rows - 1));
        const startCol = Math.round(x * (cols - 1) - phrase.length / 2);
        for (let index = 0; index < phrase.length; index += 1) {
          const letter = phrase[index];
          if (letter === " ") continue;

          const local = index / Math.max(1, phrase.length - 1);
          const col = startCol + index;
          const row =
            baseRow +
            Math.round(
              Math.sin(local * Math.PI * 2.5 + canvasTime * 0.031 + seed) * (1.4 + strength * 3) +
                Math.sin(local * Math.PI * 8 + canvasTime * 0.015 + seed) * 0.8
            );

          placeLetter(row, col, letter, strength);
        }
      }

      function addRibbon(rawPhrase, y, strength, seed, limit = 180) {
        const phrase = rawPhrase
          ? `   ${cleanPhrase(rawPhrase, limit)}   `
          : "";
        if (!phrase || strength <= 0.01) return;

        const drift = Math.floor((time * (0.34 + strength * 0.52) + seed * 9.7) % phrase.length);
        for (let col = 0; col < cols; col += 1) {
          const letter = phrase[(col + drift) % phrase.length];
          if (letter === " ") continue;

          const local = col / Math.max(1, cols - 1);
          const row =
            Math.round(y * (rows - 1)) +
            Math.round(
              Math.sin(local * Math.PI * (2.1 + strength * 1.4) + canvasTime * 0.028 + seed) *
                (1.8 + strength * 4.4) +
                Math.sin(local * Math.PI * 9.3 + canvasTime * 0.012 + seed * 0.5) * 1.1
            );

          placeLetter(row, col, letter, strength);
          if (strength > 0.58 && (col + Math.floor(seed * 10)) % 6 === 0) {
            placeLetter(row + 1, col, letter, strength * 0.7);
          }
        }
      }

      if (segment?.text) {
        const progress = clamp((time - segment.start) / Math.max(0.1, segment.end - segment.start), 0, 1);
        const reveal = smoothstep(0.04, 0.5, progress) * (1 - smoothstep(0.72, 1, progress));
        const strength = 0.5 + reveal * 0.45;
        addRibbon(segment.text, 0.54, strength, (segment.index ?? time) * 0.19, 180);
        addPhrase(segment.text, 0.5, 0.58, 0.28 + reveal * 0.28, time * 0.04, 118);
      }

      activeCues.forEach((cue) => {
        const envelope = cueEnvelope(cue, time);
        if (envelope.visible <= 0.01) return;
        const strength = envelope.visible * envelope.arrive * (1 - envelope.release * 0.78);
        addRibbon(cue.text, cue.y, strength * 0.62, cue.start, 96);
        addPhrase(cue.text, cue.x, cue.y, strength, cue.start, 72);
      });

      return letters;
    }

    function drawAsciiWaveField(width, height, time, colors, energy, activeCues, segment) {
      ctx.save();
      ctx.globalCompositeOperation = "multiply";

      const fontSize = Math.min(12.5, Math.max(9.5, Math.min(width / 108, height / 76)));
      const charWidth = fontSize * 0.78;
      const rowHeight = fontSize * 1.14;
      const cols = Math.ceil(width / charWidth) + 4;
      const rows = Math.ceil(height / rowHeight) + 4;
      const startX = -charWidth * 2;
      const startY = -rowHeight * 2;
      const centerX = 0.5;
      const centerY = 0.5;
      const activeWeight = Math.min(1, activeCues.reduce((sum, cue) => sum + cueEnvelope(cue, time).visible * 0.18, 0));
      const waveText = buildWaveTextMap(cols, rows, time, activeCues, segment);

      ctx.font = `${fontSize}px ui-monospace, SFMono-Regular, Menlo, monospace`;
      ctx.textBaseline = "top";
      for (let row = 0; row < rows; row += 1) {
        const yNorm = row / rows;
        for (let col = 0; col < cols; col += 1) {
          const xNorm = col / cols;
          const dx = xNorm - centerX;
          const dy = yNorm - centerY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const wave =
            Math.sin(col / 3 + row / 5 + canvasTime / 6.7 + dist * 10) +
            Math.cos(col / 4 - row / 3 - canvasTime / 8.3) +
            Math.sin(canvasTime / 13.3 + xNorm * Math.PI * 2);
          const charIndex = Math.floor(Math.abs((wave + 2) * (asciiChars.length / 4) + dist * 5)) % asciiChars.length;
          const x = startX + col * charWidth + Math.sin(canvasTime * 0.005 + row * 0.3) * 5;
          const y =
            startY +
            row * rowHeight +
            Math.sin(xNorm * Math.PI * 2 + canvasTime * 0.035 + row * 0.2) * 7;
          const opacity = clamp(0.09 + (1 - dist) * 0.19 + Math.sin(wave) * 0.06 + activeWeight * 0.03, 0.06, 0.38);
          const textCell = waveText.get(`${row}:${col}`);
          const glyph = textCell?.letter || asciiChars[charIndex];
          const textLift = textCell?.strength || 0;
          ctx.globalAlpha = clamp(opacity + textLift * 0.62, 0.08, 0.9) * energy;
          ctx.fillStyle = textCell
            ? `rgba(38, 24, 23, ${clamp(0.48 + textLift * 0.44, 0.48, 0.9).toFixed(3)})`
            : (row + col) % 23 === 0
              ? colors[0]
              : (row + col) % 31 === 0
                ? colors[1]
                : "rgba(38, 24, 23, 0.58)";
          ctx.fillText(glyph, x, y);
        }
      }

      ctx.restore();
    }

    function syncChrome(isPlaying) {
      const player = document.querySelector("[data-player]");
      const toggles = document.querySelectorAll("[data-player-toggle]");
      if (player) player.dataset.playing = isPlaying ? "true" : "false";
      document.documentElement.dataset.listening = isPlaying ? "true" : "false";
      toggles.forEach((toggle) => toggle.setAttribute("aria-pressed", String(isPlaying)));
    }

    async function loadTranscript() {
      if (transcript) return transcript;
      const response = await fetch("/audio/the-weather-between-us.transcript.json");
      transcript = await response.json();
      if (durationEl) durationEl.textContent = formatTime(transcript.actualDuration || transcript.estimatedDuration);
      return transcript;
    }

    function segmentAt(time) {
      if (!transcript?.segments?.length) return { segment: null, index: -1 };
      const index = transcript.segments.findIndex((segment) => time >= segment.start && time < segment.end);
      const resolved = index >= 0 ? index : time < transcript.segments[0].start ? 0 : transcript.segments.length - 1;
      return { segment: transcript.segments[resolved], index: resolved };
    }

    function renderWords(segment) {
      if (!currentEl || !segment) return;
      currentEl.textContent = segment.text;
    }

    function updateText() {
      const time = audio.currentTime || 0;
      const { segment, index } = segmentAt(time);
      if (!segment) return;

      const progress = Math.min(1, Math.max(0, (time - segment.start) / Math.max(0.1, segment.end - segment.start)));
      if (index !== activeIndex) {
        activeIndex = index;
        if (themeEl) themeEl.textContent = segment.theme;
        if (previousEl) previousEl.textContent = transcript.segments[index - 1]?.text ?? "";
        if (nextEl) nextEl.textContent = transcript.segments[index + 1]?.text ?? "";
      }

      renderWords(segment, progress);
      if (timeEl) timeEl.textContent = formatTime(time);
      if (playerTimeEl) playerTimeEl.textContent = formatTime(time);
      if (progressEl) {
        const duration = audio.duration || transcript.actualDuration || transcript.estimatedDuration || 1;
        progressEl.style.transform = `scaleX(${Math.min(1, time / duration)})`;
      }
      if (playerProgressEl) {
        const duration = audio.duration || transcript.actualDuration || transcript.estimatedDuration || 1;
        playerProgressEl.style.transform = `scaleX(${Math.min(1, time / duration)})`;
      }
    }

    function resizeCanvas() {
      if (!canvas || !ctx) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(window.innerHeight * dpr);
      canvas.style.width = `${window.innerWidth}px`;
      canvas.style.height = `${window.innerHeight}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function drawCanvas() {
      if (!ctx || !canvas) return;
      const width = window.innerWidth;
      const height = window.innerHeight;
      const audioTime = audio.currentTime || 0;
      const visualDuration = transcript?.actualDuration || audio.duration || 538;
      const time =
        audio.paused && stage.dataset.open === "true"
          ? (audioTime + canvasTime * 0.016) % visualDuration
          : audioTime;
      const segment = segmentAt(time).segment;
      const scheduledCues = poeticCues.filter((cue) => {
        const lead = Math.max(cue.lead ?? 16, 12);
        const tail = Math.max(cue.tail ?? 24, 20);
        return time >= cue.start - lead && time <= cue.end + tail;
      });
      const activeCues = scheduledCues;
      const targetTheme = activeCues[Math.floor(activeCues.length / 2)]?.theme || segment?.theme || blendedTheme;
      const targetPalette = themePalettes[targetTheme] || themePalettes.weather;
      blendedPalette = blendedPalette ? blendPalette(blendedPalette, targetPalette, 0.018) : targetPalette.map((color) => [...color]);
      blendedTheme = targetTheme;
      const colors = paletteStrings(blendedPalette);
      const energy = audio.paused ? 0.68 : 1;

      ctx.globalCompositeOperation = "source-over";
      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = "rgba(243, 216, 216, 0.94)";
      ctx.fillRect(0, 0, width, height);

      drawTopologyBands(width, height, canvasTime);
      drawAsciiWaveField(width, height, time, colors, energy, activeCues, segment);

      canvasTime += reduceMotion.matches ? 0 : 0.8;
      raf = window.requestAnimationFrame(drawCanvas);
    }

    async function open() {
      stage.dataset.open = "true";
      stage.setAttribute("aria-hidden", "false");
      syncChrome(true);
      const playPromise = audio.play();
      loadTranscript().then(updateText);
      try {
        await playPromise;
        stage.dataset.playError = "";
      } catch (_error) {
        stage.dataset.playError = _error?.name || "playback-error";
        syncChrome(false);
      }
      updateText();
      window.cancelAnimationFrame(raf);
      drawCanvas();
    }

    function pause() {
      audio.pause();
      syncChrome(false);
      updateText();
    }

    function toggle() {
      if (audio.paused) open();
      else pause();
    }

    function close() {
      pause();
      stage.dataset.open = "false";
      stage.setAttribute("aria-hidden", "true");
      window.cancelAnimationFrame(raf);
    }

    audio.addEventListener("timeupdate", updateText);
    audio.addEventListener("ended", () => syncChrome(false));
    closeButton?.addEventListener("click", close);
    window.addEventListener("resize", resizeCanvas, { passive: true });
    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && stage.dataset.open === "true") close();
    });

    resizeCanvas();
    loadTranscript().then(updateText);

    window.HumanScaleListening = { open, pause, toggle, close };
  })();
</script>
